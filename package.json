{
  "name": "@peachprojects/aggregator-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for DEX Aggregator on BSC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/mainnet-integration.test.ts",
    "test:api": "vitest run tests/api-integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "publish:test": "node version.mjs && npm publish --tag experimental"
  },
  "keywords": [
    "peach",
    "aggregator",
    "dex",
    "swap",
    "bsc",
    "pancakeswap",
    "defi"
  ],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "dotenv": "^16.3.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0",
    "undici": "^7.24.4",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}